# Copy this file to .env (or .env.local for Vite dev) and fill in values.

# ── Client (build-time, Vite) ────────────────────────────────────────────────
#
# VITE_WS_URL
#   Full WebSocket URL the browser connects to.
#   Leave unset to derive it automatically from the page origin (default).
#   Set this when the WebSocket server is on a different host or port.
#
#   Examples:
#     VITE_WS_URL=ws://localhost:3000/ws      # dev: bypass Vite proxy
#     VITE_WS_URL=wss://api.example.com/ws    # prod: external WS host
#
# VITE_WS_URL=

# ── Caddy (docker-compose) ───────────────────────────────────────────────────
#
# CADDY_HOST
#   Hostname Caddy listens on.  Use a real domain for automatic HTTPS.
#   Default: ":80"  (all interfaces, plain HTTP)
#
# CADDY_HOST=example.com

# CADDY_PORT / CADDY_HTTPS_PORT
#   Host ports mapped to Caddy's 80 / 443.  Default: 80 / 443.
#
# CADDY_PORT=80
# CADDY_HTTPS_PORT=443
